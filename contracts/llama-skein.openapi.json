      "MtpMetadata": {
        "type": "object",
        "description": "Multi-Token Prediction (MTP) capability for llama.cpp models. Enables running supported GGUF models with draft model guidance for multi-token prediction.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether MTP is enabled for this model. When true, the model command must include --spec-type draft-mtp and a draft model."
          },
          "spec_type": {
            "type": "string",
            "enum": [
              "draft-mtp"
            ],
            "description": "The spec type for draft models. For MTP-enabled models, this is always 'draft-mtp'."
          },
          "draft_n_max": {
            "type": "integer",
            "description": "Maximum draft N value (number of prompt tokens per generated token). Recommended starting point is 2 for most models."
          },
          "draft_n_tunable": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Optional list of tunable draft N values that were benchmarked on this model. If present, llama-skein will try values from this list when auto-tuning MTP."
          },
          "model_draft": {
            "type": "string",
            "description": "Optional explicit path to the draft model GGUF file. If omitted, llama-skein will automatically download the draft model from Hugging Face when MTP is enabled."
          },
          "memory_overhead_mb": {
            "type": "integer",
            "description": "Approximate additional memory overhead in MB when running this model with MTP enabled. Use this for capacity-aware scheduling."
          },
          "source": {
            "type": "string",
            "enum": [
              "config",
              "cmd"
            ],
            "description": "How this metadata was derived: 'config' for explicitly set metadata, 'cmd' for parsed values from the llama-server command string."
          }
        }
      },
