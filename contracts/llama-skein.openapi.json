{
  "openapi": "3.0.3",
  "info": {
    "title": "llama-skein control API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/system/version": {
      "get": {
        "operationId": "getSystemVersion",
        "responses": {
          "200": {
            "description": "Build and runtime version metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/system/capabilities": {
      "get": {
        "operationId": "getSystemCapabilities",
        "responses": {
          "200": {
            "description": "Supported control-plane feature flags.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Capabilities"
                }
              }
            }
          }
        }
      }
    },
    "/api/hardware": {
      "get": {
        "operationId": "getHardware",
        "responses": {
          "200": {
            "description": "Point-in-time hardware resource snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/offload/{model}": {
      "get": {
        "operationId": "getOffloadRecommendation",
        "summary": "Recommends CPU/MoE offload settings for a model given current free VRAM. MoE-scoped; non-MoE models and the mlx backend return applicable=false.",
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Model ID or alias."
          }
        ],
        "responses": {
          "200": {
            "description": "Recommended offload settings.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OffloadRecommendation"
                }
              }
            }
          },
          "404": {
            "description": "Model not found."
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "operationId": "listModels",
        "responses": {
          "200": {
            "description": "OpenAI-compatible model list enriched with llama-skein metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelList"
                }
              }
            }
          }
        }
      }
    },
    "/api/config/info": {
      "get": {
        "operationId": "getConfigInfo",
        "summary": "Returns the config file path, models directory, and per-model file-existence check.",
        "responses": {
          "200": {
            "description": "Config info response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/config/models": {
      "post": {
        "operationId": "addConfigModel",
        "summary": "Adds or replaces a model entry in the on-disk config YAML and triggers reload.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigModelRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Model added; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/config/models/{id}": {
      "get": {
        "operationId": "getConfigModel",
        "summary": "Returns the configuration and current runtime state for a specific model.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Model ID as it appears in the models map."
          }
        ],
        "responses": {
          "200": {
            "description": "Model configuration and parsed llama-server flags.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelDetail"
                }
              }
            }
          },
          "404": {
            "description": "Model not found in config."
          }
        }
      },
      "patch": {
        "operationId": "patchConfigModel",
        "summary": "Updates selected config fields and common llama-server flags without requiring callers to reconstruct the whole command string.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Model ID as it appears in the models map."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigModelPatchRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Model updated; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "404": {
            "description": "Model not found in config."
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      },
      "delete": {
        "operationId": "removeConfigModel",
        "summary": "Removes the model entry from the config YAML without touching the file on disk.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Model ID as it appears in the models map."
          }
        ],
        "responses": {
          "202": {
            "description": "Model removed; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "404": {
            "description": "Model not found in config."
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/config/groups/{id}": {
      "patch": {
        "operationId": "patchConfigGroup",
        "summary": "Updates selected group config fields (autoUnload, exclusive, swap) without requiring callers to reconstruct the whole group configuration.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Group ID."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigGroupPatchRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Group updated; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "404": {
            "description": "Group not found in config."
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/config/reload": {
      "post": {
        "operationId": "reloadConfig",
        "summary": "Re-reads the config file from disk and restarts the proxy manager.",
        "responses": {
          "202": {
            "description": "Reload initiated asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReloadResponse"
                }
              }
            }
          },
          "503": {
            "description": "Reload not available."
          }
        }
      }
    },
    "/api/config/default-model": {
      "get": {
        "operationId": "getDefaultModel",
        "summary": "Returns the configured default model used when a request omits the 'model' field.",
        "responses": {
          "200": {
            "description": "Default model info. 'model' is null when no default is configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigDefaultModelResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "setDefaultModel",
        "summary": "Sets the default model in the on-disk config YAML and triggers reload. The model must be a configured model ID or alias.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigDefaultModelRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Default model updated; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "404": {
            "description": "Model not found in config."
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      },
      "delete": {
        "operationId": "clearDefaultModel",
        "summary": "Removes the default model from the on-disk config YAML and triggers reload. Idempotent.",
        "responses": {
          "202": {
            "description": "Default model cleared; reload triggered asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigModelResponse"
                }
              }
            }
          },
          "422": {
            "description": "Config file path not set."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/fit": {
      "get": {
        "operationId": "getFitReport",
        "summary": "Fit report for every configured model on this host: fit level, max-safe context, throughput estimate. The per-host payload skein aggregates for fleet placement.",
        "responses": {
          "200": {
            "description": "Per-host fit report.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FitReport"
                }
              }
            }
          }
        }
      }
    },
    "/api/fit/{model}": {
      "get": {
        "operationId": "getModelFit",
        "summary": "Fit of one model to this host. Optional ctx query scores a specific context size instead of computing the max-safe one.",
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Model ID or alias."
          },
          {
            "name": "ctx",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Score this context size instead of computing max_safe_ctx."
          }
        ],
        "responses": {
          "200": {
            "description": "Fit result for the model.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelFit"
                }
              }
            }
          },
          "404": {
            "description": "Model not found."
          }
        }
      }
    },
    "/api/tuning": {
      "get": {
        "operationId": "getTuning",
        "summary": "Effective GPU tuning for this host (detected arch, enabled state, resolved profile, provenance).",
        "responses": {
          "200": {
            "description": "Tuning status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TuningStatus"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "patchTuning",
        "summary": "Override or disable the recommended tuning for this host (persisted; applied on next model reload).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TuningPatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated tuning status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TuningStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/tuning/profiles": {
      "get": {
        "operationId": "listTuningProfiles",
        "summary": "The full tuning database (all gfx x use-case profiles) for client pickers.",
        "responses": {
          "200": {
            "description": "Tuning database.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TuningProfilesResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Capabilities": {
        "type": "object",
        "required": [
          "version",
          "features"
        ],
        "properties": {
          "version": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "VersionInfo": {
        "type": "object",
        "required": [
          "version",
          "commit",
          "build_date",
          "runtime"
        ],
        "properties": {
          "version": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "build_date": {
            "type": "string"
          },
          "runtime": {
            "type": "object",
            "additionalProperties": true
          },
          "llama_cpp_build": {
            "type": "string"
          },
          "llama_cpp_git": {
            "type": "string"
          },
          "llama_cpp_date": {
            "type": "string"
          },
          "build_features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "platform": {
            "type": "string"
          },
          "metal": {
            "type": "boolean"
          },
          "rocm_version": {
            "type": "string"
          }
        }
      },
      "ResourceSnapshot": {
        "type": "object",
        "properties": {
          "storage": {
            "$ref": "#/components/schemas/StorageInfo"
          },
          "memory": {
            "$ref": "#/components/schemas/MemoryInfo"
          },
          "cpu": {
            "$ref": "#/components/schemas/CPUInfo"
          },
          "gpus": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GPUSnapshot"
            }
          },
          "vram": {
            "$ref": "#/components/schemas/VRAMInfo"
          },
          "loaded_model": {
            "$ref": "#/components/schemas/LoadedModelInfo"
          },
          "inference": {
            "$ref": "#/components/schemas/InferenceInfo"
          }
        }
      },
      "InferenceInfo": {
        "type": "object",
        "description": "Live inference load: in-flight model-dispatched requests vs. serving slots. The exact busy signal for schedulers — GPU utilization is sampled over a window and reads low between tokens; this does not.",
        "properties": {
          "in_flight": {
            "type": "integer",
            "description": "Model-dispatched HTTP requests currently being served, including any queued behind a model load or a busy slot."
          },
          "slots_total": {
            "type": "integer",
            "description": "Total serving slots across running models (--parallel/-np per model command, default 1 each). 0 when no model is running."
          },
          "busy": {
            "type": "boolean",
            "description": "True when every slot of every running model is occupied (in_flight >= slots_total > 0) — a new request would queue. False when no model is running: the host is idle, it just needs a swap-in."
          }
        }
      },
      "LoadedModelInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Model ID as defined in config. With several models loaded, the one with the largest weights is reported (ties: smallest ID) \u2014 selection is deterministic across calls."
          },
          "model_mb": {
            "type": "integer",
            "description": "Model weight file size in MB (disk proxy for VRAM used by weights)."
          },
          "kv_estimate_mb": {
            "type": "integer",
            "description": "Estimated KV cache MB. On GPU hosts: max(0, vram.used_mb - model_mb). When that yields 0 (CPU-only inference, no GPU telemetry), falls back to the fit engine's GGUF-derived KV size at the model's usable context."
          }
        }
      },
      "StorageInfo": {
        "type": "object",
        "properties": {
          "models_dir": {
            "type": "string"
          },
          "total_bytes": {
            "type": "integer"
          },
          "used_bytes": {
            "type": "integer"
          },
          "available_bytes": {
            "type": "integer"
          }
        }
      },
      "MemoryInfo": {
        "type": "object",
        "properties": {
          "total_mb": {
            "type": "integer"
          },
          "used_mb": {
            "type": "integer"
          },
          "free_mb": {
            "type": "integer"
          },
          "swap_total": {
            "type": "integer"
          },
          "swap_used": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "load_avg1": {
            "type": "number"
          },
          "load_avg5": {
            "type": "number"
          },
          "load_avg15": {
            "type": "number"
          }
        }
      },
      "CPUInfo": {
        "type": "object",
        "properties": {
          "cores": {
            "type": "integer"
          },
          "util_avg_pct": {
            "type": "number"
          },
          "util_per_core": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "load_avg1": {
            "type": "number"
          },
          "load_avg5": {
            "type": "number"
          },
          "load_avg15": {
            "type": "number"
          }
        }
      },
      "GPUSnapshot": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "vram_total_mb": {
            "type": "integer"
          },
          "vram_used_mb": {
            "type": "integer"
          },
          "vram_free_mb": {
            "type": "integer"
          },
          "utilization_pct": {
            "type": "number"
          },
          "temp_c": {
            "type": "integer"
          },
          "power_draw_w": {
            "type": "number"
          }
        }
      },
      "VRAMInfo": {
        "type": "object",
        "properties": {
          "total_mb": {
            "type": "integer"
          },
          "used_mb": {
            "type": "integer"
          },
          "free_mb": {
            "type": "integer"
          }
        }
      },
      "ModelList": {
        "type": "object",
        "required": [
          "object",
          "data"
        ],
        "properties": {
          "object": {
            "type": "string",
            "enum": [
              "list"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            }
          }
        }
      },
      "Model": {
        "type": "object",
        "required": [
          "id",
          "object"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "created": {
            "type": "integer"
          },
          "owned_by": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "loaded": {
            "type": "boolean"
          },
          "context_length": {
            "type": "integer"
          },
          "max_output_tokens": {
            "type": "integer"
          },
          "n_cpu_moe": {
            "type": "integer",
            "description": "Current --n-cpu-moe value parsed from the model command, when set (llama.cpp MoE expert CPU offload)."
          },
          "cpu_moe": {
            "type": "boolean",
            "description": "True when --cpu-moe is present in the model command (all MoE experts offloaded to CPU)."
          },
          "cpu_offload_gb": {
            "type": "integer",
            "description": "Current --cpu-offload-gb value parsed from the model command, when set (vLLM weight offload)."
          },
          "override_tensor": {
            "type": "string",
            "description": "Current --override-tensor value parsed from the model command, when set (llama.cpp tensor placement)."
          },
          "backend": {
            "type": "string",
            "enum": [
              "llamacpp",
              "mlx",
              "vllm"
            ],
            "description": "Inference backend type."
          },
          "default": {
            "type": "boolean",
            "description": "True when this model is the configured default, used for requests that omit the 'model' field. Listed first in the model list. llama-skein extension to the OpenAI schema."
          },
          "metadata": {
            "type": "object",
            "description": "Optional capability metadata for this model. llama-skein extension for MTP and other runtime capabilities.",
            "properties": {
              "mtp": {
                "$ref": "#/components/schemas/MtpMetadata"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "ConfigInfoResponse": {
        "type": "object",
        "required": [
          "config_file",
          "models_dir",
          "model_count",
          "models"
        ],
        "properties": {
          "config_file": {
            "type": "string"
          },
          "models_dir": {
            "type": "string"
          },
          "model_count": {
            "type": "integer"
          },
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConfigModelInfo"
            }
          },
          "default_model": {
            "type": "string",
            "description": "Configured default model ID; omitted when no default is set."
          }
        }
      },
      "ConfigModelInfo": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "file_path": {
            "type": "string"
          },
          "file_exists": {
            "type": "boolean"
          }
        }
      },
      "ConfigModelRequest": {
        "type": "object",
        "required": [
          "id",
          "cmd"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "cmd": {
            "type": "string"
          },
          "backend": {
            "type": "string",
            "enum": [
              "llamacpp",
              "mlx",
              "vllm"
            ],
            "description": "Inference backend type. Controls backend-specific behaviours (e.g. slot cancellation is llamacpp-only). mlx targets Apple Silicon; vllm targets NVIDIA (CUDA); AMD ROCm requires building vllm from source. Default: llamacpp."
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ttl": {
            "type": "integer"
          },
          "n_cpu_moe": {
            "type": "integer",
            "description": "Number of leading layers whose MoE expert tensors are offloaded to CPU/RAM (llama.cpp --n-cpu-moe). llamacpp only."
          },
          "cpu_moe": {
            "type": "boolean",
            "description": "Offload ALL MoE expert tensors to CPU/RAM (llama.cpp --cpu-moe). llamacpp only."
