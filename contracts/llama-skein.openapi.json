          },
          "configured_ctx": {
            "type": "integer",
            "description": "Current --ctx-size in the model command (the KV allocation / hard n_ctx)."
          },
          "max_safe_ctx": {
            "type": "integer",
            "description": "Max context callers should fill: reserves the output budget plus compute/overhead so prompt+generation never exceed the backend's hard n_ctx, and accounts for llama-server dividing n_ctx across --parallel slots (per-request share). THIS is the number opencode/skein should trim to, not configured_ctx."
          },
          "model_mb": {
            "type": "integer",
            "description": "Model weights resident size (MB)."
          },
          "kv_mb_at_max_safe_ctx": {
            "type": "integer",
            "description": "KV-cache size (MB) at max_safe_ctx, given the host's cache-type quantization."
          },
          "vram_total_mb": {
            "type": "integer",
            "description": "Total VRAM/unified memory pool (MB)."
          },
          "vram_required_mb": {
            "type": "integer",
            "description": "Estimated VRAM needed: weights + KV + compute buffers (MB)."
          },
          "est_tokens_per_sec": {
            "type": "number",
            "description": "Estimated generation throughput on this host (benchmark-derived)."
          },
          "score": {
            "$ref": "#/components/schemas/FitScore"
          },
          "reason": {
            "type": "string",
            "description": "Human-readable explanation of the fit verdict."
          }
        }
