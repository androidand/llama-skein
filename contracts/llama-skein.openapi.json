        "description": "Fit of one model to THIS host: whether it runs, how well, and the max SAFE context (output- and overhead-reserved). Ported from llmfit fit.rs ModelFit.",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model ID."
          },
          "backend": {
            "type": "string",
            "enum": [
              "llamacpp",
              "mlx",
              "vllm"
